---
import "../styles/global.css";
import BlobField from "../components/background/BlobField.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Home",
  description = "Zachary Sorensen McNellis — software engineer in San Francisco.",
} = Astro.props;

const fullTitle = `${title} | Zachary McNellis`;

// Only emit analytics in production builds so local dev traffic isn't tracked.
const isProd = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
    <meta name="theme-color" content="#f6f1e7" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- favicons (preserved from the previous site) -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Computer Modern (LaTeX) web fonts -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/aaaakshat/cm-web-fonts@latest/fonts.css"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />

    <!-- Pre-hide animated elements (only when motion is allowed); reveal as a
         failsafe if the animation script never runs. Runs before paint. -->
    <script is:inline>
      (function () {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.documentElement.classList.add("anim");
        addEventListener("load", function () {
          setTimeout(function () {
            if (!document.documentElement.classList.contains("anim-ready")) {
              document.documentElement.classList.remove("anim");
            }
          }, 1500);
        });
      })();
    </script>

    <!-- Cloudflare Web Analytics (privacy-friendly, cookieless). Prod only so
         local dev traffic doesn't pollute stats. Token is public by design. -->
    {
      isProd && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon='{"token": "9b70de63bd5f4316ba75aa1563e5a3fb"}'
        ></script>
      )
    }
  </head>
  <body>
    <BlobField />
    <Header />
    <main class="page-main">
      <slot />
    </main>
    <Footer />

    <script>
      import { gsap } from "gsap";

      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        // mark ready so the head failsafe stands down
        document.documentElement.classList.add("anim-ready");

        // Reveal everything on load with a gentle stagger (no scroll gating).
        gsap.fromTo(
          "[data-animate]",
          { opacity: 0, y: 22 },
          { opacity: 1, y: 0, duration: 0.7, ease: "power2.out", stagger: 0.06 }
        );
      }
    </script>
  </body>
</html>
