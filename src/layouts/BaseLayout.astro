---
import "../styles/global.css";
import BlobField from "../components/background/BlobField.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Zachary Sorensen McNellis",
  description = "Zachary Sorensen McNellis — software engineer in San Francisco.",
} = Astro.props;

const fullTitle =
  title === "Zachary Sorensen McNellis"
    ? title
    : `${title} · Zachary S. McNellis`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- favicons (preserved from the previous site) -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-icon-180x180.png" />
    <link rel="manifest" href="/manifest.json" />

    <!-- Computer Modern (LaTeX) web fonts -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/aaaakshat/cm-web-fonts@latest/fonts.css"
    />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />

    <!-- Pre-hide animated elements (only when motion is allowed); reveal as a
         failsafe if the animation script never runs. Runs before paint. -->
    <script is:inline>
      (function () {
        if (matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        document.documentElement.classList.add("anim");
        addEventListener("load", function () {
          setTimeout(function () {
            if (!document.documentElement.classList.contains("anim-ready")) {
              document.documentElement.classList.remove("anim");
            }
          }, 1500);
        });
      })();
    </script>
  </head>
  <body>
    <BlobField />
    <Header />
    <main class="page-main">
      <slot />
    </main>
    <Footer />

    <script>
      import { gsap } from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";

      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        gsap.registerPlugin(ScrollTrigger);
        // mark ready so the head failsafe stands down
        document.documentElement.classList.add("anim-ready");

        const items = gsap.utils.toArray<HTMLElement>("[data-animate]");
        items.forEach((el, i) => {
          gsap.fromTo(
            el,
            { opacity: 0, y: 22 },
            {
              opacity: 1,
              y: 0,
              duration: 0.7,
              ease: "power2.out",
              delay: Math.min(i, 8) * 0.05,
              scrollTrigger: { trigger: el, start: "top 88%", once: true },
            }
          );
        });
      }
    </script>
  </body>
</html>
