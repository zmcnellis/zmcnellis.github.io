---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import profile from "../assets/profile.jpg";

const pages = [
  { href: "/bio", title: "Bio", blurb: "Background, what I build, and how I got here." },
  { href: "/resume", title: "Resume", blurb: "Experience, skills, and a PDF to download." },
  { href: "/fun", title: "Fun stuff", blurb: "Experiments, visuals, and side projects." },
];
---

<BaseLayout>
  <section class="document hero">
    <Image
      src={profile}
      alt="Portrait of Zachary Sorensen McNellis"
      class="portrait"
      width={160}
      height={160}
      densities={[1, 2]}
    />
    <p class="label">Software Engineer · San Francisco</p>
    <h1>Zachary Sorensen McNellis</h1>
    <p class="lede">
      I'm a software engineer based in San Francisco. I like building things
      that are fast, careful, and a little bit playful — with the occasional
      detour into graphics and simulation (the blobs drifting behind this page
      are a real&nbsp;fluid&nbsp;solver).
    </p>
    <SocialLinks class="hero-social" />
  </section>

  <hr class="rule" />

  <nav class="document index-nav" aria-label="Sections">
    <ul>
      {
        pages.map((p) => (
          <li>
            <a href={p.href} class="index-card">
              <span class="index-title">{p.title}</span>
              <span class="index-blurb muted">{p.blurb}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</BaseLayout>

<style>
  .hero {
    text-align: left;
  }
  .portrait {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--rule-strong);
    margin-bottom: var(--space-4);
  }
  .hero h1 {
    margin: var(--space-1) 0 var(--space-3);
    font-size: var(--fs-3xl);
  }
  .lede {
    font-size: var(--fs-lg);
    color: var(--ink);
    max-width: 60ch;
  }
  .hero-social {
    margin-top: var(--space-4);
  }
  .index-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
  .index-card {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rule);
    border-radius: 4px;
    background: color-mix(in srgb, var(--bg-raised) 70%, transparent);
    transition: border-color 0.18s ease, background 0.18s ease;
  }
  .index-card:hover {
    border-color: var(--rule-strong);
    background: var(--bg-raised);
    color: var(--ink);
  }
  .index-title {
    font-weight: 700;
    font-size: var(--fs-lg);
  }
  .index-blurb {
    font-size: var(--fs-sm);
  }
</style>
