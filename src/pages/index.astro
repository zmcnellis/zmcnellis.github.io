---
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import profile from "../assets/profile.jpg";

const pages = [
  { href: "/bio", title: "Bio", blurb: "Background, what I build, and how I got here." },
  { href: "/resume", title: "Resume", blurb: "Experience, skills, and a PDF to download." },
  { href: "/fun", title: "Fun stuff", blurb: "Interactive demos, a Skyrim mod, and graphics experiments." },
];
---

<BaseLayout title="Home">
  <section class="document hero">
    <span class="portrait-wrap" data-animate>
      <Image
        src={profile}
        alt="Portrait of Zachary Sorensen McNellis"
        class="portrait"
        width={160}
        height={160}
        densities={[1, 2]}
      />
    </span>
    <p class="label" data-animate>Software Engineer · San Francisco</p>
    <h1 data-animate>Zachary Sorensen McNellis</h1>
    <p class="lede" data-animate>
      I'm a software engineer in San Francisco with 10+ years of experience and
      a master's in computer science (computer graphics). I'm a senior engineer
      at Webflow, and was previously an engineering manager at Shipt (acquired
      by Target). Most of my career has been at small startups, where I've come
      to love the scrappy blend of creativity and problem-solving. Off the
      clock, you'll probably catch me rollerblading around the city on light-up
      wheels — usually with my dog Boulder on the leash.
    </p>
    <SocialLinks class="hero-social" data-animate />
  </section>

  <hr class="rule" data-animate />

  <nav class="document index-nav" aria-label="Sections">
    <ul>
      {
        pages.map((p) => (
          <li data-animate>
            <a href={p.href} class="index-card">
              <span class="index-card__body">
                <span class="index-title">{p.title}</span>
                <span class="index-blurb muted">{p.blurb}</span>
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</BaseLayout>

<style>
  .hero {
    text-align: left;
  }

  /* ---- Portrait with animated rainbow glow on hover ---- */
  .portrait-wrap {
    position: relative;
    z-index: 0;
    display: inline-block;
    border-radius: 50%;
    margin-bottom: var(--space-4);
  }
  .portrait-wrap::before {
    content: "";
    position: absolute;
    inset: -10px;
    border-radius: 50%;
    background: conic-gradient(from var(--glow-angle), var(--rainbow-stops));
    filter: blur(16px);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
  }
  .portrait-wrap:hover::before {
    opacity: 0.9;
    animation: glow-spin 4s linear infinite;
  }
  .portrait {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--rule-strong);
    transition: transform 0.4s ease;
  }
  .portrait-wrap:hover .portrait {
    transform: scale(1.03);
  }

  .hero h1 {
    margin: var(--space-1) 0 var(--space-3);
    font-size: var(--fs-3xl);
  }
  .lede {
    font-size: var(--fs-lg);
    color: var(--ink);
    max-width: 60ch;
  }
  .hero-social {
    margin-top: var(--space-4);
  }

  /* ---- Section index card grid (card styles live in global.css) ---- */
  .index-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-3);
  }
</style>
