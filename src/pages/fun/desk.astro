---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Desk Scene"
  description="A cozy CSS-only desk scene — flickering lamp, steaming coffee, and a live alarm clock."
>
  <article class="document">
    <p class="label" data-animate>
      <a href="/fun" class="back">← Fun stuff</a>
    </p>
    <h1 data-animate>Desk Scene</h1>
    <hr class="rule" data-animate />

    <p data-animate>
      This is a fun little CSS animation I built after being inspired by various
      posts on CodePen. It's meant to look like my desk, and features a
      flickering lamp, steaming coffee, and an alarm clock. Everything is done
      with pure HTML &amp; CSS except for a small snippet of JavaScript to get
      the current time for the clock — so the clock you see below is the real
      time.
    </p>

    <div class="embed" data-animate>
      <iframe
        src="https://codepen.io/zmcnellis/full/ybobjB"
        title="Desk Scene — CodePen by Zachary McNellis"
        loading="lazy"
        allowfullscreen
      ></iframe>
    </div>

    <p data-animate>
      You can check out the
      <a href="https://codepen.io/zmcnellis/full/ybobjB" target="_blank" rel="noopener noreferrer">
        live version</a
      >
      or
      <a href="https://codepen.io/zmcnellis/pen/ybobjB" target="_blank" rel="noopener noreferrer">
        dig into the code</a
      >
      on CodePen.
    </p>
  </article>
</BaseLayout>

<style>
  .back {
    border-bottom: none;
    color: var(--ink-faint);
  }
  .back:hover {
    color: var(--accent);
  }
  .embed {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    margin: var(--space-4) 0;
    border: 1px solid var(--rule);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-sunk);
  }
  .embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
